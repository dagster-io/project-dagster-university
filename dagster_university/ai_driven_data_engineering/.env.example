# MinIO / S3 (for local development with docker-compose)
# Copy to .env and run: docker compose up -d
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Use this when using MINIO_DOMAIN=localhost.localstack.cloud in docker-compose:
AWS_ENDPOINT_URL_S3=http://localhost.localstack.cloud:9000
# Or use http://localhost:9000 if connecting to MinIO directly
